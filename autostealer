local AutoFarmEnabled = false
local AutoSellEnabled = false

local function StartAutoFarm()
    spawn(function()
        while AutoFarmEnabled do
            wait(0.3)
            local Plots = workspace:FindFirstChild("Plots")
            if Plots then
                for _, Plot in pairs(Plots:GetChildren()) do
                    pcall(function()
                        if Plot:GetAttribute("IsReady") then
                            local HarvestRemote = RS:FindFirstChild("HarvestPlant") or RS:FindFirstChild("ReplicaSignal")
                            if HarvestRemote then
                                HarvestRemote:FireServer(Plot)
                            end
                        end
                    end)
                end
            end
        end
    end)
end

local function StartAutoSell()
    spawn(function()
        while AutoSellEnabled do
            wait(0.5)
            for _, Tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                pcall(function()
                    local SellRemote = RS:FindFirstChild("SellItem") or RS:FindFirstChild("ReplicaSignal")
                    if SellRemote then
                        SellRemote:FireServer(Tool)
                    end
                end)
                wait(0.1)
            end
        end
    end)
end

