-- 1. ПЕРЕХВАТЫВАЕМ ВСЕ RemoteEvent В ReplicatedStorage
local function scanAll(obj, path)
    path = path or ""
    for _, child in pairs(obj:GetChildren()) do
        local currentPath = path ~= "" and path .. "." .. child.Name or child.Name
        
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            if not foundEvents[currentPath] then
                foundEvents[currentPath] = true
                table.insert(eventList, currentPath)
                print("🎯 [EVENT] " .. currentPath)
                
                -- ПЕРЕХВАТ ДЛЯ RemoteEvent
                if child:IsA("RemoteEvent") then
                    local oldFire = child.FireServer
                    child.FireServer = function(self, ...)
                        print("📡 ВЫЗОВ: " .. currentPath .. " | АРГУМЕНТЫ:", ...)
                        return oldFire(self, ...)
                    end
                end
            end
        end
        
        if child:IsA("Folder") or child:IsA("Model") then
            scanAll(child, currentPath)
        end
    end
end

scanAll(RS)

