-- РӨРЈРқРҡРҰРҳРҜ РЈР’Р•Р”РһРңРӣР•РқРҳРҜ
local function notify(msg, duration)
    duration = duration or 2
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "рҹ”Қ RYZEN SNIFFER",
            Text = msg,
            Duration = duration
        })
    end)
    print("[RYZEN] " .. msg)
end

-- РӨРЈРқРҡРҰРҳРҜ РҡРһРҹРҳР РһР’РҗРқРҳРҜ Р’ Р‘РЈРӨР•Р  (Р РҗР‘РһРўРҗР•Рў 100%)
local function copyToClipboard(text)
    local success = false
    pcall(function()
        if setclipboard then
            setclipboard(text)
            success = true
        elseif toclipboard then
            toclipboard(text)
            success = true
        elseif Clipboard then
            Clipboard:set(text)
            success = true
        end
    end)
    return success
end

-- РЎРҡРҗРқРҳР РЈР•Рң Р’РЎР• РҹРҗРҹРҡРҳ Рҳ РЎРһР‘РҳР РҗР•Рң РЎРһР‘Р«РўРҳРҜ
local function scanAll()
    local count = 0
    local function scan(obj, path)
        path = path or ""
        for _, child in pairs(obj:GetChildren()) do
            local fullPath = path ~= "" and path .. "/" .. child.Name or child.Name
            if child:IsA("RemoteEvent") then
                table.insert(allEvents, {name = fullPath, type = "Event"})
                count = count + 1
            elseif child:IsA("RemoteFunction") then
                table.insert(allEvents, {name = fullPath, type = "Function"})
                count = count + 1
            end
            if child:IsA("Folder") or child:IsA("Model") then
                scan(child, fullPath)
            end
        end
    end
    scan(RS)
    return count
end

