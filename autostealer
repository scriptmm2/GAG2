        notify("📋 ВЕСЬ СПИСОК В БУФЕРЕ! ВСТАВЬ СЮДА")
        
        -- ПОКАЗЫВАЕМ ПЕРВЫЕ 3 В УВЕДОМЛЕНИЯХ
        local i = 0
