-- ADVANCED DUPE SYSTEM (3 DIFFERENT METHODS)
-- ============================================================================
local dupeHistory = {}
local dupeCount = 0

-- Method 1: Lag switch dupe (race condition)
local function lagSwitchDupe()
    local character = player.Character
    if not character then return false end
    
    local tool = character:FindFirstChildWhichIsA("Tool")
    if not tool then return false end
    
    -- Create massive lag
    for i = 1, 1000 do
        local dummyPart = Instance.new("Part")
        dummyPart.CFrame = CFrame.new(math.random(-10000, 10000), math.random(-10000, 10000), math.random(-10000, 10000))
        dummyPart.Parent = workspace
        game:GetService("Debris"):AddItem(dummyPart, 0.1)
    end
    
    wait(0.05)
    
    -- Duplicate the tool
    local clone = tool:Clone()
    clone.Parent = player.Backpack
    
    -- Remove lag
    wait(0.1)
    for _, part in ipairs(workspace:GetChildren()) do
        if part:IsA("Part") and part.Name == "" and part.Size == Vector3.one then
            part:Destroy()
        end
    end
    
    dupeCount = dupeCount + 1
    table.insert(dupeHistory, {item = tool.Name, time = os.time(), method = "LagSwitch"})
    
    return true
end

-- Method 2: Remote double-tap dupe
local function remoteDupe()
    local remotes = replicatedStorage:FindFirstChild("Remotes")
    if not remotes then return false end
    
    local itemRemote = remotes:FindFirstChild("ItemAction") or remotes:FindFirstChild("UseItem") or remotes:FindFirstChild("DropItem")
    if not itemRemote then return false end
    
    local character = player.Character
    if not character then return false end
    
    local tool = character:FindFirstChildWhichIsA("Tool")
    if not tool then return false end
    
    -- Send duplicate packets
    for i = 1, 5 do
        pcall(function()
            itemRemote:FireServer("duplicate", tool.Name, tool:GetAttribute("ID") or 0)
            itemRemote:FireServer("clone", tool.Name, tool:GetAttribute("ID") or 0)
        end)
        wait(0.01)
    end
    
    dupeCount = dupeCount + 1
    table.insert(dupeHistory, {item = tool.Name, time = os.time(), method = "RemoteTap"})
    
    return true
end

-- Method 3: Memory injection dupe (most advanced)
local function memoryDupe()
    local character = player.Character
    if not character then return false end
    
    local tool = character:FindFirstChildWhichIsA("Tool")
    if not tool then return false end
    
    -- Hijack the item's metadata
    local metadata = getrawmetatable and getrawmetatable(tool) or debug and debug.getmetatable(tool)
    if metadata then
        local oldIndex = metadata.__index
        metadata.__index = function(t, k)
            if k == "Parent" then
                return oldIndex(t, k)
            end
            return oldIndex(t, k)
        end
    end
    
    -- Create ghost item
    local ghostItem = tool:Clone()
    ghostItem.Name = tool.Name .. "_dupe_" .. tostring(math.random(1000, 9999))
    
    -- Inject into player's inventory directly
    local inventory = player:FindFirstChild("Inventory") or player:FindFirstChild("Backpack")
    if inventory then
        ghostItem.Parent = inventory
    else
        ghostItem.Parent = player.Backpack
    end
    
    dupeCount = dupeCount + 1
    table.insert(dupeHistory, {item = tool.Name, time = os.time(), method = "MemoryInjection"})
    
    return true
end

-- Main dupe function with method selection
local function executeDupe(method)
    if method == 1 then
        return lagSwitchDupe()
    elseif method == 2 then
        return remoteDupe()
    elseif method == 3 then
        return memoryDupe()
    else
        -- Auto-select best method
        local methods = {lagSwitchDupe, remoteDupe, memoryDupe}
        for _, m in ipairs(methods) do
            local success = m()
            if success then return true end
        end
        return false
    end
end

