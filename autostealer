local autoFarmEnabled = false
local autoFarmConnection = nil
local farmSettings = {
    collectDrops = true,
    waterPlants = true,
    harvestReady = true,
    plantSeeds = true,
    autoMerge = true,
    autoHatch = true,
    radius = 50
}

local function collectNearbyItems()
    local character = player.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Part") or obj:IsA("MeshPart") then
            local distance = (obj.Position - hrp.Position).Magnitude
            if distance < farmSettings.radius and obj:FindFirstChild("ClickDetector") then
                fireclickdetector(obj.ClickDetector)
                wait(0.05)
            elseif distance < farmSettings.radius and obj:IsA("Tool") then
                local character = player.Character
                if character then
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        obj.CFrame = hrp.CFrame + Vector3.new(0, 3, 0)
                        wait(0.1)
                    end
                end
            end
        end
    end
end

local function waterNearbyPlants()
    -- Find plant pots and water them
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:find("Plant") or obj.Name:find("Pot") then
            if obj:FindFirstChild("WaterLevel") then
                local waterRemote = replicatedStorage:FindFirstChild("Remotes"):FindFirstChild("WaterPlant")
                if waterRemote then
                    pcall(function()
                        waterRemote:FireServer(obj)
                    end)
                end
            end
        end
        wait(0.05)
    end
end

local function harvestReadyPlants()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:FindFirstChild("IsReady") and obj.IsReady.Value == true then
            local harvestRemote = replicatedStorage:FindFirstChild("Remotes"):FindFirstChild("Harvest")
            if harvestRemote then
                pcall(function()
                    harvestRemote:FireServer(obj)
                end)
            end
        end
        wait(0.05)
    end
end

local function autoMergePets()
    local inventory = player:FindFirstChild("Inventory") or player:FindFirstChild("PlayerGui"):FindFirstChild("Inventory")
    if not inventory then return end
    
    -- Find duplicate pets
    local petCounts = {}
    for _, pet in ipairs(inventory:GetChildren()) do
        if pet:IsA("Folder") or pet:IsA("Model") then
            local petName = pet.Name
            petCounts[petName] = (petCounts[petName] or 0) + 1
        end
    end
    
    for petName, count in pairs(petCounts) do
        if count >= 2 then
            local mergeRemote = replicatedStorage:FindFirstChild("Remotes"):FindFirstChild("MergePets")
            if mergeRemote then
                for i = 1, math.floor(count / 2) do
                    pcall(function()
                        mergeRemote:FireServer(petName)
                    end)
                    wait(0.1)
                end
            end
        end
    end
end

local function autoHatchEggs()
    local inventory = player:FindFirstChild("Inventory") or player:FindFirstChild("Backpack")
    if not inventory then return end
    
    for _, item in ipairs(inventory:GetChildren()) do
        if item.Name:find("Egg") or item:GetAttribute("Type") == "Egg" then
            local hatchRemote = replicatedStorage:FindFirstChild("Remotes"):FindFirstChild("HatchEgg")
            if hatchRemote then
                pcall(function()
                    hatchRemote:FireServer(item)
                end)
                wait(0.2)
            end
        end
    end
end

local function startAutoFarm()
    if autoFarmConnection then autoFarmConnection:Disconnect() end
    
    autoFarmConnection = runService.RenderStepped:Connect(function()
        if not autoFarmEnabled then return end
        
        if farmSettings.collectDrops then collectNearbyItems() end
        if farmSettings.waterPlants then waterNearbyPlants() end
        if farmSettings.harvestReady then harvestReadyPlants() end
        if farmSettings.autoMerge then autoMergePets() end
        if farmSettings.autoHatch then autoHatchEggs() end
        
        wait(0.5)
    end)
end

local function stopAutoFarm()
    if autoFarmConnection then
        autoFarmConnection:Disconnect()
        autoFarmConnection = nil
    end
end

