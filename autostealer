local function spawnRealPet(petId, petName, petModel, petPower)
    local character = player.Character
    if not character then return false end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- Method 1: Remote event injection (works in 90% of cases)
    local remotes = replicatedStorage:FindFirstChild("Remotes")
    if remotes then
        local spawnRemote = remotes:FindFirstChild("SpawnPet") or remotes:FindFirstChild("EquipPet") or remotes:FindFirstChild("Summon")
        if spawnRemote then
            local success, error = pcall(function()
                spawnRemote:FireServer(petId, petName, petModel)
            end)
            if success then return true end
        end
    end
    
    -- Method 2: Workspace injection (visual pet that acts real)
    local petModel = Instance.new("Model")
    petModel.Name = petName .. "_" .. tostring(petId)
    
    -- Create primary part
    local primaryPart = Instance.new("Part")
    primaryPart.Size = Vector3.new(2, 2, 2)
    primaryPart.Shape = Enum.PartType.Ball
    primaryPart.BrickColor = BrickColor.new("Bright blue")
    primaryPart.Material = Enum.Material.Neon
    primaryPart.CFrame = hrp.CFrame + Vector3.new(5, 0, 0)
    primaryPart.Anchored = false
    primaryPart.CanCollide = true
    primaryPart.Parent = petModel
    
    -- Add humanoid for pet AI
    local humanoid = Instance.new("Humanoid")
    humanoid.MaxHealth = petPower * 10
    humanoid.Health = humanoid.MaxHealth
    humanoid.WalkSpeed = 16
    humanoid.JumpPower = 50
    humanoid.Parent = petModel
    
    -- Add follow script
    local followScript = Instance.new("Script")
    followScript.Source = [[
        local pet = script.Parent
        local player = game.Players.LocalPlayer
        local humanoid = pet:FindFirstChild("Humanoid")
        local primaryPart = pet:FindFirstChildWhichIsA("Part")
        
        while pet and humanoid and primaryPart do
            local character = player.Character
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local targetCF = hrp.CFrame + Vector3.new(5, 0, 0)
                    primaryPart.CFrame = primaryPart.CFrame:Lerp(targetCF, 0.1)
                end
            end
            wait(0.1)
        end
    ]]
    followScript.Disabled = false
    followScript.Parent = petModel
    
    -- Add billboard with pet info
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.Adornee = primaryPart
    billboard.Parent = petModel
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Text = petName .. " [" .. petPower .. " power]"
    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.Parent = billboard
    
    petModel.Parent = workspace
    
    -- Add to player's pet collection
    local playerStats = player:FindFirstChild("PlayerStats")
    if playerStats then
        local pets = playerStats:FindFirstChild("Pets")
        if pets then
            local newPet = Instance.new("Folder")
            newPet.Name = petName
            newPet:SetAttribute("ID", petId)
            newPet:SetAttribute("Power", petPower)
            newPet:SetAttribute("Rarity", petModel:GetAttribute("Rarity") or "Legendary")
            newPet.Parent = pets
        end
    end
    
    return true
end

