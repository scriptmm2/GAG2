local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

print("========== RYZEN SNIFFER ==========")
print("Ищу Remote Events в ReplicatedStorage...")

-- НАХОДИМ ВСЕ СОБЫТИЯ
local events = {}
local folders = {RS}

-- ОБХОДИМ ВСЕ ПАПКИ
for _, obj in pairs(RS:GetChildren()) do
    if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
        table.insert(events, obj.Name)
        print("🔹 НАЙДЕНО СОБЫТИЕ:", obj.Name)
    elseif obj:IsA("Folder") then
        for _, sub in pairs(obj:GetChildren()) do
            if sub:IsA("RemoteEvent") or sub:IsA("RemoteFunction") then
                table.insert(events, obj.Name .. "/" .. sub.Name)
                print("🔸 В ПАПКЕ " .. obj.Name .. ":", sub.Name)
            end
        end
    end
end

print("========== ИТОГО НАЙДЕНО: " .. #events .. " ==========")

-- ПОПРОБУЕМ НАЙТИ СОБЫТИЯ ПО КЛЮЧЕВЫМ СЛОВАМ
local keywords = {"Harvest", "Sell", "Plant", "Aura", "Water", "Fertilize", "Buy", "Upgrade"}

print("========== ПОИСК ПО КЛЮЧЕВЫМ СЛОВАМ ==========")
for _, keyword in pairs(keywords) do
    for _, name in pairs(events) do
        if string.find(string.lower(name), string.lower(keyword)) then
            print("✅", keyword, "→", name)
        end
    end
end

