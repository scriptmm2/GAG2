local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local foundEvents = {}
local capturedEvents = {}

-- УВЕДОМЛЕНИЕ
local function notify(msg)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🔍 RYZEN",
            Text = msg,
            Duration = 3
        })
    end)
    print(msg)
end

-- ФУНКЦИЯ КОПИРОВАНИЯ В БУФЕР
local function copyToClipboard(text)
    pcall(function()
        if setclipboard then
            setclipboard(text)
            return true
        elseif toclipboard then
            toclipboard(text)
            return true
        end
    end)
    return false
end

-- СОБИРАЕМ ВСЕ СОБЫТИЯ ЗАРАНЕЕ
local function scanAll()
    local count = 0
    local function scan(obj, path)
        path = path or ""
        for _, child in pairs(obj:GetChildren()) do
            local fullPath = path ~= "" and path .. "/" .. child.Name or child.Name
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                if not foundEvents[fullPath] then
                    foundEvents[fullPath] = true
                    count = count + 1
                end
            end
            if child:IsA("Folder") or child:IsA("Model") then
                scan(child, fullPath)
            end
        end
    end
    scan(RS)
    return count
end

local totalEvents = scanAll()
notify("📡 НАЙДЕНО " .. totalEvents .. " СОБЫТИЙ")
wait(1)
notify("🎯 ТЕПЕРЬ ДЕЛАЙ ДЕЙСТВИЯ В ИГРЕ")

-- ПЕРЕХВАТ ВСЕХ ВЫЗОВОВ
for _, event in pairs(RS:GetDescendants()) do
    if event:IsA("RemoteEvent") then
        local oldFire = event.FireServer
        local eventPath = event:GetFullName()
        
        event.FireServer = function(self, ...)
            if not capturedEvents[eventPath] then
                capturedEvents[eventPath] = true
                
                -- ПОЛУЧАЕМ АРГУМЕНТЫ
                local args = {...}
                local argInfo = ""
                for i, arg in pairs(args) do
                    if i > 3 then break end
                    if type(arg) == "Instance" then
                        argInfo = argInfo .. "[" .. arg.ClassName .. ":" .. arg.Name .. "] "
                    elseif type(arg) == "string" then
                        argInfo = argInfo .. '"' .. arg .. '" '
                    elseif type(arg) == "number" then
                        argInfo = argInfo .. arg .. " "
                    else
                        argInfo = argInfo .. type(arg) .. " "
                    end
                end
                
                notify("🔥 " .. eventPath)
                if argInfo ~= "" then
                    print("   АРГУМЕНТЫ: " .. argInfo)
                end
                
                -- АВТОМАТИЧЕСКИ КОПИРУЕМ КАЖДОЕ НОВОЕ СОБЫТИЕ
                copyToClipboard(eventPath)
                
                -- ПОКАЗЫВАЕМ СТАТУС
                local count = 0
                for _ in pairs(capturedEvents) do count = count + 1 end
                notify("📋 СКОПИРОВАНО " .. count .. "/?")
            end
            return oldFire(self, ...)
        end
    end
end

-- ТАКЖЕ СЛЕДИМ ЗА RemoteFunction
for _, event in pairs(RS:GetDescendants()) do
    if event:IsA("RemoteFunction") then
        local oldInvoke = event.InvokeServer
        local eventPath = event:GetFullName()
        
        event.InvokeServer = function(self, ...)
            if not capturedEvents[eventPath] then
                capturedEvents[eventPath] = true
                notify("⚡ " .. eventPath)
                copyToClipboard(eventPath)
                local count = 0
                for _ in pairs(capturedEvents) do count = count + 1 end
                notify("📋 СКОПИРОВАНО " .. count)
            end
            return oldInvoke(self, ...)
        end
    end
end

-- ФИНАЛЬНОЕ УВЕДОМЛЕНИЕ ЧЕРЕЗ 30 СЕКУНД
