-- ФУНКЦИЯ ОБХОДА ВСЕХ ДИРЕКТОРИЙ
local function scanFolder(folder, path)
    path = path or ""
    for _, child in pairs(folder:GetChildren()) do
        local currentPath = path ~= "" and path .. "/" .. child.Name or child.Name
        
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            table.insert(allEvents, currentPath)
            print("🎯 [EVENT] " .. currentPath)
        elseif child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            -- ДУБЛИРУЕМ НА ВСЯКИЙ
        end
        
        if child:IsA("Folder") or child:IsA("Model") then
            scanFolder(child, currentPath)
        end
    end
end

-- СКАНИРУЕМ ReplicatedStorage
print("\n📁 СКАНИРУЮ ReplicatedStorage...")
