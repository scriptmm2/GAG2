-- Ryzen Visual Dupe + Pet Spawner for "Grow a Garden 2"
-- Futuristic GUI
-- Работает локально, сервер не дублирует предметы

local player = game.Players.LocalPlayer
local mouse = player:GetMouse()

-- Создаём главное GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.Name = "RyzenFutureGUI"

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 400, 0, 500)
mainFrame.Position = UDim2.new(0.5, -200, 0.5, -250)
mainFrame.BackgroundTransparency = 0.2
mainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

-- Неоновый бордюр
local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 12)
uiCorner.Parent = mainFrame

local uiStroke = Instance.new("UIStroke")
uiStroke.Thickness = 2
uiStroke.Color = Color3.fromRGB(0, 255, 255)
uiStroke.Transparency = 0.3
uiStroke.Parent = mainFrame

-- Заголовок
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 40)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "⚡ RYZEN DUPE v2.0 ⚡"
title.TextColor3 = Color3.fromRGB(0, 255, 255)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

-- === ВИЗУАЛЬНЫЙ ДЮП ===
local dupeButton = Instance.new("TextButton")
dupeButton.Size = UDim2.new(0.8, 0, 0, 50)
dupeButton.Position = UDim2.new(0.1, 0, 0.15, 0)
dupeButton.BackgroundColor3 = Color3.fromRGB(30, 30, 60)
dupeButton.Text = "🌀 ВИЗУАЛЬНЫЙ ДЮП ПРЕДМЕТА"
dupeButton.TextColor3 = Color3.fromRGB(0, 255, 255)
dupeButton.Font = Enum.Font.Gotham
dupeButton.Parent = mainFrame

local uiCornerBtn = Instance.new("UICorner")
uiCornerBtn.CornerRadius = UDim.new(0, 8)
uiCornerBtn.Parent = dupeButton

dupeButton.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end
    local rightHand = char:FindFirstChild("RightHand")
    if not rightHand then return end
    
    local tool = char:FindFirstChildWhichIsA("Tool")
    if tool then
        -- Визуальная копия
        local clone = tool:Clone()
        clone.Parent = player.Backpack
        clone.Name = tool.Name .. "_Dupe"
        
        -- Эффект в руке
        local beam = Instance.new("Part")
        beam.Size = Vector3.new(0.5, 0.5, 0.5)
        beam.BrickColor = BrickColor.new("Cyan")
        beam.Material = Enum.Material.Neon
        beam.CFrame = rightHand.CFrame
        beam.Anchored = true
        beam.Parent = game.Workspace
        game:GetService("Debris"):AddItem(beam, 1)
        
        -- Сообщение
        local notif = Instance.new("TextLabel")
        notif.Text = "✅ Визуальный дюп: " .. tool.Name
        notif.BackgroundColor3 = Color3.fromRGB(0,0,0)
        notif.TextColor3 = Color3.fromRGB(0,255,255)
        notif.Size = UDim2.new(0, 300, 0, 30)
        notif.Position = UDim2.new(0.5, -150, 0.8, 0)
        notif.Parent = screenGui
        game:GetService("Debris"):AddItem(notif, 2)
    else
        local notif = Instance.new("TextLabel")
        notif.Text = "❌ Нет предмета в руке"
        notif.BackgroundColor3 = Color3.fromRGB(0,0,0)
        notif.TextColor3 = Color3.fromRGB(255,0,0)
        notif.Size = UDim2.new(0, 300, 0, 30)
        notif.Position = UDim2.new(0.5, -150, 0.8, 0)
        notif.Parent = screenGui
        game:GetService("Debris"):AddItem(notif, 2)
    end
end)

-- === PET SPAWNER для Grow a Garden 2 ===
local petButton = Instance.new("TextButton")
petButton.Size = UDim2.new(0.8, 0, 0, 50)
petButton.Position = UDim2.new(0.1, 0, 0.35, 0)
petButton.BackgroundColor3 = Color3.fromRGB(30, 30, 60)
petButton.Text = "🐾 ПРИЗВАТЬ ПИТОМЦА"
petButton.TextColor3 = Color3.fromRGB(0, 255, 200)
petButton.Font = Enum.Font.Gotham
petButton.Parent = mainFrame

local uiCornerPet = Instance.new("UICorner")
uiCornerPet.CornerRadius = UDim.new(0, 8)
uiCornerPet.Parent = petButton

petButton.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Создаём визуального питомца (куб-неон)
    local pet = Instance.new("Part")
    pet.Size = Vector3.new(1.5, 1.5, 1.5)
    pet.Shape = Enum.PartType.Ball
    pet.BrickColor = BrickColor.new("Bright violet")
    pet.Material = Enum.Material.Neon
    pet.CFrame = hrp.CFrame + hrp.CFrame.LookVector * 3 + Vector3.new(0, 1, 0)
    pet.Anchored = false
    pet.CanCollide = true
    pet.Parent = game.Workspace
    
    -- Прикрепляем свет
    local pointLight = Instance.new("PointLight")
    pointLight.Color = Color3.fromRGB(150, 0, 255)
    pointLight.Range = 8
    pointLight.Brightness = 2
    pointLight.Parent = pet
    
    -- Имя питомца
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.Adornee = pet
    billboard.Parent = pet
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Text = "✨ Ryzen Pet ✨"
    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Size = UDim2.new(1,0,1,0)
    nameLabel.Parent = billboard
    
    -- Анимация
    local tweenService = game:GetService("TweenService")
    local info = TweenInfo.new(2, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
    local target = {Size = Vector3.new(2, 2, 2)}
    local tween = tweenService:Create(pet, info, target)
    tween:Play()
    
    -- Удалить через 30 сек
    game:GetService("Debris"):AddItem(pet, 30)
end)

-- Футуристическая анимация рамки
game:GetService("TweenService"):Create(
    uiStroke,
    TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
    {Transparency = 0.7}
):Play()
