-- в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ РҹР•Р Р•РҘР’РҗРў Р’Р«Р—РһР’РһР’ (Р“РӣРҗР’РқРһР•) в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ

local hookCount = 0
local hookedEvents = {}

for _, event in pairs(RS:GetDescendants()) do
    if (event:IsA("RemoteEvent") or event:IsA("RemoteFunction")) and not hookedEvents[event] then
        hookedEvents[event] = true
        
        if event:IsA("RemoteEvent") then
            local oldFire = event.FireServer
            local eventName = event:GetFullName()
            
            event.FireServer = function(self, ...)
                -- Р—РҗРҹРһРңРҳРқРҗР•Рң РЎРһР‘Р«РўРҳР•
                if not capturedEvents[eventName] then
                    capturedEvents[eventName] = true
                    hookCount = hookCount + 1
                    
                    -- РҹРһРӣРЈР§РҗР•Рң РҗР Р“РЈРңР•РқРўР«
                    local args = {...}
                    local argStr = ""
                    for i = 1, math.min(3, #args) do
                        local arg = args[i]
                        if type(arg) == "Instance" then
                            argStr = argStr .. "[" .. arg.ClassName .. ":" .. (arg.Name or "?") .. "] "
                        elseif type(arg) == "string" then
                            argStr = argStr .. '"' .. arg .. '" '
                        elseif type(arg) == "number" then
                            argStr = argStr .. arg .. " "
                        elseif type(arg) == "boolean" then
                            argStr = argStr .. tostring(arg) .. " "
                        else
                            argStr = argStr .. type(arg) .. " "
                        end
                    end
                    
                    -- РҹРһРҡРҗР—Р«Р’РҗР•Рң РЈР’Р•Р”РһРңРӣР•РқРҳР•
                    notify("рҹ”Ҙ " .. eventName, 2)
                    
                    -- РҡРһРҹРҳР РЈР•Рң Р’ Р‘РЈРӨР•Р 
                    copyToClipboard(eventName)
                    
                    -- РЎРһРҘР РҗРқРҜР•Рң Р’ РўР•РҡРЎРў
                    saveText = saveText .. eventName .. "\n"
                    if argStr ~= "" then
                        saveText = saveText .. "   вҶ’ " .. argStr .. "\n"
                    end
                end
                
                return oldFire(self, ...)
            end
        end
        
        if event:IsA("RemoteFunction") then
            local oldInvoke = event.InvokeServer
            local eventName = event:GetFullName()
            
            event.InvokeServer = function(self, ...)
                if not capturedEvents[eventName] then
                    capturedEvents[eventName] = true
                    hookCount = hookCount + 1
                    notify("вҡЎ " .. eventName, 2)
                    copyToClipboard(eventName)
                    saveText = saveText .. eventName .. "\n"
                end
                return oldInvoke(self, ...)
            end
        end
    end
end

