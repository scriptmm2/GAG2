-- ОТДЕЛЬНО ВЫДЕЛЯЕМ ПОДОЗРИТЕЛЬНЫЕ НА ФАРМ
local farmKeywords = {"farm", "harvest", "sell", "plant", "seed", "aura", "water", "fertil", "crop", "fruit", "garden", "plot", "grow", "collect", "buy", "upgrade", "shop", "inventory", "tool", "item"}
local found = {}

print("\n🔎 ПОИСК ПО КЛЮЧЕВЫМ СЛОВАМ:")
for _, keyword in pairs(farmKeywords) do
    for _, eventName in pairs(allEvents) do
        if string.find(string.lower(eventName), keyword) then
            if not found[eventName] then
                found[eventName] = true
                print("   ✅ [" .. keyword:upper() .. "] → " .. eventName)
            end
        end
    end
end

