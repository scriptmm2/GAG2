local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local foundEvents = {}
local lastNotify = 0

-- УВЕДОМЛЕНИЕ
local function notify(msg)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🔍 RYZEN",
            Text = msg,
            Duration = 4
        })
    end)
    print(msg)
end

-- ПЕРЕХВАТ ВСЕХ ВЫЗОВОВ
local function hookEvents()
    for _, event in pairs(RS:GetDescendants()) do
        if event:IsA("RemoteEvent") and not event._hooked then
            event._hooked = true
            local oldFire = event.FireServer
            local eventName = event:GetFullName()
            
            event.FireServer = function(self, ...)
                if not foundEvents[eventName] then
                    foundEvents[eventName] = true
                    
                    -- ПОЛУЧАЕМ АРГУМЕНТЫ
                    local args = {...}
                    local argStr = ""
                    for i = 1, math.min(2, #args) do
                        local arg = args[i]
                        if type(arg) == "Instance" then
                            argStr = argStr .. "[" .. arg.ClassName .. ":" .. (arg.Name or "?") .. "] "
                        elseif type(arg) == "string" then
                            argStr = argStr .. '"' .. arg .. '" '
                        elseif type(arg) == "number" then
                            argStr = argStr .. arg .. " "
                        end
                    end
                    
                    -- ПОКАЗЫВАЕМ В УВЕДОМЛЕНИИ
                    local total = 0
                    for _ in pairs(foundEvents) do total = total + 1 end
                    
                    notify("🔹 " .. eventName)
                    if argStr ~= "" then
                        notify("   → " .. argStr)
                    end
                    notify("📌 НАЙДЕНО: " .. total .. " шт.")
                end
                
                return oldFire(self, ...)
            end
        end
    end
end

-- ПЕРЕХВАТ RemoteFunction
local function hookFunctions()
    for _, event in pairs(RS:GetDescendants()) do
        if event:IsA("RemoteFunction") and not event._hooked then
            event._hooked = true
            local oldInvoke = event.InvokeServer
            local eventName = event:GetFullName()
            
            event.InvokeServer = function(self, ...)
                if not foundEvents[eventName] then
                    foundEvents[eventName] = true
                    local total = 0
                    for _ in pairs(foundEvents) do total = total + 1 end
                    notify("⚡ " .. eventName)
                    notify("📌 НАЙДЕНО: " .. total .. " шт.")
                end
                return oldInvoke(self, ...)
            end
        end
    end
end

hookEvents()
hookFunctions()

-- ОБНОВЛЯЕМ ПЕРЕХВАТ КОГДА ДОБАВЛЯЮТСЯ НОВЫЕ СОБЫТИЯ
RS.ChildAdded:Connect(function()
    wait(0.5)
    hookEvents()
    hookFunctions()
end)

